# ============================================================
# WonderKid Stories — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=WonderKid Stories <noreply@wonderkidstories.com>

# AI Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
IMAGE_PROVIDER_API_KEY=

# Queue (Inngest)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Storage buckets (must match Supabase bucket names)
STORAGE_BUCKET_CHILD_PHOTOS=child-photos
STORAGE_BUCKET_BOOK_ASSETS=book-assets
STORAGE_BUCKET_PDFS=pdfs

# Admin
ADMIN_EMAIL=admin@wonderkidstories.com

# ============================================================
# MOCK MODE — Set to true to use mock AI and payment
# Allows full workflow testing without paid API calls
# ============================================================
MOCK_AI_MODE=true
MOCK_PAYMENT_MODE=true
